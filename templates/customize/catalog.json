          "name": "ERROR_MESSAGE_TEMPLATE",
          "description": "エラーメッセージテンプレート",
          "type": "string",
          "required": false,
          "default": "{label}は必須項目です"
        }
      ],
      "file": "patterns/validate_required.js",
      "events": [
        "app.record.create.submit",
        "app.record.edit.submit"
      ]
    },
    {
      "id": "auto_numbering",
      "name": "自動採番",
      "category": "auto",
      "description": "レコード保存時に独自フォーマットで自動採番する",
      "keywords": ["採番", "連番", "番号", "自動", "ナンバリング", "シーケンス"],

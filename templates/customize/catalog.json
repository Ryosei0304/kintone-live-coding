{
  "version": "2.0.0",
  "description": "kintoneカスタマイズパターンカタログ（公式ドキュメント準拠版）",
  "patterns": [
    {
      "id": "field_show_hide",
      "name": "フィールド表示/非表示制御",
      "category": "field_control",
      "description": "特定の条件でフィールドを表示/非表示にする",
      "keywords": ["表示", "非表示", "隠す", "見せる", "条件", "表示制御"],
      "parameters": [
        {
          "name": "TRIGGER_FIELD",
          "description": "トリガーとなるフィールドコード",
          "type": "string",
          "required": true
        },
        {
          "name": "CONDITION_VALUE",
          "description": "条件となる値",
          "type": "string",
          "required": true
        },
        {
          "name": "TARGET_FIELDS",
          "description": "対象フィールドコードの配列",
          "type": "array",
          "required": true
        },
        {
          "name": "SHOW_WHEN_MATCH",
          "description": "条件一致時に表示するか",
          "type": "boolean",
          "required": false,
          "default": true
        }
      ],
      "file": "patterns/field_show_hide.js",
      "events": [
        "app.record.create.show",
        "app.record.edit.show",
        "app.record.create.change.{TRIGGER_FIELD}",
        "app.record.edit.change.{TRIGGER_FIELD}"
      ]
    },
    {
      "id": "field_disable",
      "name": "フィールド編集不可制御",
      "category": "field_control",
      "description": "特定の条件でフィールドを編集不可にする",
      "keywords": ["編集不可", "読み取り専用", "ロック", "無効化", "disabled"],
      "parameters": [
        {
          "name": "TRIGGER_FIELD",
          "description": "トリガーとなるフィールドコード",
          "type": "string",
          "required": true
        },
        {
          "name": "CONDITION_VALUE",
          "description": "条件となる値",
          "type": "string",
          "required": true
        },
        {
          "name": "TARGET_FIELDS",
          "description": "対象フィールドコードの配列",
          "type": "array",
          "required": true
        }
      ],
      "file": "patterns/field_disable.js",
      "events": [
        "app.record.create.show",
        "app.record.edit.show",
        "app.record.create.change.{TRIGGER_FIELD}",
        "app.record.edit.change.{TRIGGER_FIELD}"
      ]
    },
    {
      "id": "condition_status",
      "name": "ステータス分岐制御",
      "category": "condition",
      "description": "ステータスフィールドの値に応じて処理を分岐",
      "keywords": ["ステータス", "状態", "分岐", "条件分岐", "状況"],
      "parameters": [
        {
          "name": "STATUS_FIELD",
          "description": "ステータスフィールドコード",
          "type": "string",
          "required": true
        },
        {
          "name": "CONDITIONS",
          "description": "条件と処理の配列",
          "type": "array",
          "required": true,
          "schema": {
            "status": "ステータス値",
            "action": "処理内容（show_hide/disable/set_value）",
            "target_fields": "対象フィールドの配列",
            "value": "セットする値（set_valueの場合）"
          }
        }
      ],
      "file": "patterns/condition_status.js",
      "events": [
        "app.record.create.show",
        "app.record.edit.show",
        "app.record.create.change.{STATUS_FIELD}",
        "app.record.edit.change.{STATUS_FIELD}"
      ]
    },
    {
      "id": "style_section_header",
      "name": "セクション見出し",
      "category": "style",
      "description": "スペーサーにセクション見出しを追加してフォームをグルーピング",
      "keywords": ["見出し", "セクション", "グループ", "区切り", "ヘッダー", "タイトル"],

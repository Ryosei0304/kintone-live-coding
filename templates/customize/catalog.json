    {
      "id": "validate_required",
      "name": "条件付き必須チェック",
      "category": "validation",
      "description": "特定の条件で必須チェックを行う",
      "keywords": ["必須", "入力チェック", "バリデーション", "検証", "エラー"],
      "parameters": [
        {
          "name": "CONDITION_FIELD",
          "description": "条件となるフィールドコード",
          "type": "string",
          "required": true
        },
        {
          "name": "CONDITION_VALUE",
          "description": "条件となる値",
          "type": "string",
          "required": true
        },
        {
          "name": "REQUIRED_FIELDS",
          "description": "必須チェック対象フィールドの配列",
          "type": "array",
          "required": true,
          "schema": {
            "field": "フィールドコード",
            "label": "フィールド名（エラーメッセージ用）"
